{% extends 'base.html.twig' %}

{% block title %}Pending Projects{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_dashboard') }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Dashboard
    </a>

    <div class="card shadow-sm">
        <div class="card-body">

            <h1 class="mb-4">⏳ Pending Project Approvals</h1>

            {% if pendingProjects is empty %}
                <div class="alert alert-info mb-0">
                    No pending projects.
                </div>
            {% else %}
                {% for project in pendingProjects %}
                    <div class="d-flex justify-content-between align-items-center border-bottom py-3">

                        <div>
                            <h5 class="mb-1">{{ project.name }}</h5>

                            <small class="text-muted d-block">
                                Workspace: {{ project.workspace.name }}
                            </small>

                            <small class="text-muted d-block">
                                Status: {{ project.approvalStatus }}
                            </small>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_project_approve', {'id': project.id}) }}"
                               class="btn btn-sm btn-success">
                                Approve
                            </a>

                            <a href="{{ path('app_project_reject', {'id': project.id}) }}"
                               class="btn btn-sm btn-outline-danger">
                                Reject
                            </a>
                        </div>

                    </div>
                {% endfor %}
            {% endif %}

        </div>
    </div>

</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Delete Workspace{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="card border-danger shadow-sm">
        <div class="card-body">

            <h1 class="text-danger mb-3">
                Delete Workspace
            </h1>

            <div class="alert alert-danger">
                This action is permanent. It will delete this workspace, all projects,
                all tasks, invitations, members and related activity data.
            </div>

            <p>
                To confirm deletion, type the workspace name:
            </p>

            <p>
                <strong>{{ workspace.name }}</strong>
            </p>

            <form method="post"
                  action="{{ path('app_workspace_delete_confirm', {'id': workspace.id}) }}">

                <div class="mb-3">
                    <input type="text"
                           name="workspace_name"
                           class="form-control"
                           placeholder="Type workspace name exactly"
                           required>
                </div>

                <div class="d-flex gap-2">
                    <button type="button"
                            class="btn btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteWorkspaceModal">
                        Permanently delete workspace
                    </button>

                    <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
                       class="btn btn-outline-secondary">
                        Cancel
                    </a>
                </div>

                <div class="modal fade"
                     id="deleteWorkspaceModal"
                     tabindex="-1"
                     aria-labelledby="deleteWorkspaceModalLabel"
                     aria-hidden="true">

                    <div class="modal-dialog">
                        <div class="modal-content">

                            <div class="modal-header">
                                <h5 class="modal-title" id="deleteWorkspaceModalLabel">
                                    Delete Workspace
                                </h5>

                                <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="modal">
                                </button>
                            </div>

                            <div class="modal-body">
                                <p>
                                    Are you sure you want to delete
                                    <strong>{{ workspace.name }}</strong>?
                                </p>

                                <div class="alert alert-warning mb-0">
                                    This action will permanently delete the workspace and all
                                    projects, tasks, members, invitations and activity history.
                                </div>
                            </div>

                            <div class="modal-footer">
                                <button type="button"
                                        class="btn btn-secondary"
                                        data-bs-dismiss="modal">
                                    Cancel
                                </button>

                                <button type="submit"
                                        class="btn btn-danger">
                                    Yes, delete workspace
                                </button>
                            </div>

                        </div>
                    </div>

                </div>

            </form>

        </div>
    </div>

</div>
{% endblock %}
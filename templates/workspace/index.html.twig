{% extends 'base.html.twig' %}

{% block title %}My Workspaces{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Workspaces</h1>

        <a href="{{ path('app_workspace_new') }}"
           class="btn btn-primary">
            + New Workspace
        </a>
    </div>

    <h3 class="mb-3">My Workspaces</h3>

    {% if ownedWorkspaces is empty %}
        <div class="alert alert-info">
            You don't own any workspace yet.
        </div>
    {% else %}
        <div class="row">
            {% for workspace in ownedWorkspaces %}
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">
                                {{ workspace.name }}
                            </h5>

                            <p class="text-muted small">
                                {{ workspace.description|default('No description') }}
                            </p>

                            <div class="mt-auto">
                                <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
                                   class="btn btn-primary btn-sm">
                                    Open Workspace
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <hr class="my-5">

    <h3 class="mb-3">Shared With Me</h3>

    {% if invitedWorkspaces is empty %}
        <div class="alert alert-secondary">
            No shared workspaces.
        </div>
    {% else %}
        <div class="row">
            {% for workspace in invitedWorkspaces %}
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-info h-100">
                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title">
                                {{ workspace.name }}
                            </h5>

                            <p class="text-muted small">
                                {{ workspace.description|default('No description') }}
                            </p>

                            <div class="mt-auto">
                                <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
                                   class="btn btn-outline-info btn-sm">
                                    Open Workspace
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
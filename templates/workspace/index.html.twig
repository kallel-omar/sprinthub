{% extends 'base.html.twig' %}

{% block title %}My Workspaces{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Workspaces</h1>
        <a href="{{ path('app_workspace_new') }}" class="btn btn-primary">Create Workspace</a>
    
    </div>

    {% if workspaces is empty %}
        <div class="alert alert-info">
            You don't have any workspaces yet.
        </div>
    {% else %}
        <div class="row">
    {% for workspace in workspaces %}
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5>{{ workspace.name }}</h5>
                <p class="text-muted">{{ workspace.slug }}</p>

                <a href="{{ path('app_project_new', {'id': workspace.id}) }}"
                   class="btn btn-success btn-sm">
                    Create Project
                </a>
                <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
   class="btn btn-outline-primary btn-sm">
    Open
</a>

    <a href="{{ path('app_workspace_delete', {'id': workspace.id}) }}"
       class="btn btn-danger"
       onclick="return confirm('Delete this workspace and all its data?')">
        Delete Workspace
    </a>

            </div>
        </div>
    </div>
{% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}{{ workspace.name }}{% endblock %}

{% block body %}
<div class="container mt-5">
    <a href="{{ path('app_workspace_index') }}" class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Workspaces
    </a>

    {% set currentRole = null %}
    {% for member in workspace.members %}
        {% if member.user == app.user %}
            {% set currentRole = member.role %}
        {% endif %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>{{ workspace.name }}</h1>

            <p class="text-muted">
                {{ workspace.slug }}
                {% if currentRole %}
                    <span class="badge bg-dark ms-2">{{ currentRole }}</span>
                {% endif %}
            </p>
        </div>
        

        {% if currentRole in ['owner', 'admin'] %}
            <div class="d-flex gap-2">
                <a href="{{ path('app_project_new', {'id': workspace.id}) }}" class="btn btn-primary">
                    Create Project
                </a>

                <a href="{{ path('app_workspace_members', {'id': workspace.id}) }}" class="btn btn-outline-primary">
                    Members
                </a>

                <a href="{{ path('app_workspace_analytics', {'id': workspace.id}) }}" class="btn btn-outline-success">
                    Analytics
                </a>

                {% if currentRole == 'owner' %}
                    <a href="{{ path('app_workspace_delete', {'id': workspace.id}) }}" class="btn btn-outline-danger">
                        Delete Workspace
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </div>
    <div class="row mb-4 mt-4">
        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6 class="text-muted">Projects</h6>
                    <h2>{{ totalProjects }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6 class="text-muted">Tasks</h6>
                    <h2>{{ totalTasks }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6 class="text-muted">Completed</h6>
                    <h2>{{ completedPercentage }}%</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6 class="text-muted">Members</h6>
                    <h2>{{ membersCount }}</h2>
                </div>
            </div>
        </div>
    </div>
<div class="row mb-4">

    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                Tasks by Status
            </div>

            <div class="card-body text-center">
                <div style="max-width: 300px; margin: auto;">
                    <canvas id="tasksStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card shadow-sm h-100">
            <div class="card-header">
                Tasks by Priority
            </div>

            <div class="card-body text-center">
                <div style="max-width: 300px; margin: auto;">
                    <canvas id="tasksPriorityChart"></canvas>
                </div>
             
            </div>
        </div>
    </div>
    

</div>
    
    <h3>Projects</h3>

    {% if workspace.projects is empty %}
        <div class="alert alert-info mt-3">
            No projects yet in this workspace.
        </div>
    {% else %}
        <div class="row mt-3">
            {% for project in workspace.projects %}
                {% if project.approvalStatus != 'rejected' %}
                    <div class="col-md-4">
                        <div class="card mb-3 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5>{{ project.name }}</h5>

                                    {% if project.approvalStatus == 'pending' %}
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    {% elseif project.approvalStatus == 'approved' %}
                                        <span class="badge bg-success">Approved</span>
                                    {% endif %}
                                </div>

                                <p class="text-muted">
                                    {{ project.description|default('No description') }}
                                </p>

                                {% if project.approvalStatus == 'pending' %}
                                    {% if currentRole == 'owner' %}
                                        <div class="d-flex gap-2">
                                            <a href="{{ path('app_project_approve', {'id': project.id}) }}"
                                               class="btn btn-success btn-sm">
                                                Approve
                                            </a>

                                            <a href="{{ path('app_project_reject', {'id': project.id}) }}"
                                               class="btn btn-danger btn-sm"
                                               onclick="return confirm('Are you sure you want to reject this project?');">
                                                Reject
                                            </a>
                                        </div>
                                    {% else %}
                                        <button class="btn btn-outline-secondary btn-sm" disabled>
                                            Waiting for owner approval
                                        </button>
                                    {% endif %}
                                {% else %}
                                    <a href="{{ path('app_project_show', {'id': project.id}) }}"
                                       class="btn btn-outline-primary btn-sm">
                                        Open Project
                                    </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </div>
    {% endif %}
<div class="card shadow-sm mb-4">
    <div class="card-header">
        Upcoming Deadlines
    </div>

    <div class="card-body">
    <p>Upcoming count: {{ upcomingTasks|length }}</p>
        {% if upcomingTasks is not empty %}
            <div class="list-group">
                {% for task in upcomingTasks %}
                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                       class="list-group-item list-group-item-action">

                        <strong>{{ task.title }}</strong>

                        <small class="text-muted d-block">
                            Project: {{ task.project.name }}
                        </small>

                        <small class="text-muted d-block">
                            Due: {{ task.dueDate|date('d/m/Y H:i') }}
                        </small>

                    </a>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-muted mb-0">
                No upcoming deadlines.
            </p>
        {% endif %}
    </div>
</div>
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            Latest Projects
        </div>

        <div class="card-body">
            {% if latestProjects is not empty %}
                <div class="list-group">
                    {% for project in latestProjects %}
                        <a href="{{ path('app_project_show', {'id': project.id}) }}"
                           class="list-group-item list-group-item-action">
                            <strong>{{ project.name }}</strong>

                            <small class="text-muted d-block">
                                {{ project.createdAt|date('d/m/Y H:i') }}
                            </small>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted mb-0">No projects yet.</p>
            {% endif %}
        </div>
    </div>
    <div class="card shadow-sm mb-4">
    <div class="card-header">
        Latest Tasks
    </div>

    <div class="card-body">

        {% if latestTasks is not empty %}

            <div class="list-group">

                {% for task in latestTasks %}
                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                       class="list-group-item list-group-item-action">

                        <div class="d-flex justify-content-between">

                            <div>
                                <strong>{{ task.title }}</strong>

                                <small class="text-muted d-block">
                                    {{ task.project.name }}
                                </small>
                            </div>

                            <div class="text-end">

                                <span class="badge bg-secondary">
                                    {{ task.status }}
                                </span>

                                <span class="badge bg-info">
                                    {{ task.priority }}
                                </span>

                            </div>

                        </div>

                    </a>
                {% endfor %}

            </div>

        {% else %}

            <p class="text-muted mb-0">
                No tasks yet.
            </p>

        {% endif %}

    </div>
</div>

    

    <div class="card shadow-sm mb-4 mt-4">
        <div class="card-header">
            Recent Activity
        </div>

        <div class="card-body">
            {% if recentActivity is not empty %}
                <ul class="list-group list-group-flush">
                    {% for activity in recentActivity %}
                        <li class="list-group-item">
                            {{ activity.message }}

                            <small class="text-muted d-block">
                                {{ activity.createdAt|date('d/m/Y H:i') }}
                            </small>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="text-muted mb-0">No recent activity yet.</p>
            {% endif %}
        </div>
    </div>
</div>




<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
const ctx = document.getElementById('tasksStatusChart');

new Chart(ctx, {
    type: 'doughnut',
    data: {
        labels: ['Todo', 'In Progress', 'Done'],
        datasets: [{
            data: [
                {{ todoTasks }},
                {{ inProgressTasks }},
                {{ doneTasks }}
            ]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});
</script>

<script>
const priorityCtx = document.getElementById('tasksPriorityChart');

new Chart(priorityCtx, {
    type: 'doughnut',
    data: {
        labels: ['Low', 'Medium', 'High'],
        datasets: [{
            data: [
                {{ lowPriorityTasks }},
                {{ mediumPriorityTasks }},
                {{ highPriorityTasks }}
            ]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});
</script>

{% endblock %}

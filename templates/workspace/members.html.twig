{% extends 'base.html.twig' %}

{% block title %}{{ workspace.name }} Members{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Workspace
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ workspace.name }} Members</h1>

        <a href="{{ path('app_workspace_invite', {'id': workspace.id}) }}"
           class="btn btn-outline-warning">
            Invite Member
        </a>
    </div>

    {% if inviteLink %}
        <div class="alert alert-success">
            <strong>Invitation link generated:</strong>

            <div class="input-group mt-2">
                <input type="text"
                       class="form-control"
                       value="{{ inviteLink }}"
                       readonly>

                <button class="btn btn-outline-secondary"
                        type="button"
                        onclick="navigator.clipboard.writeText('{{ inviteLink }}')">
                    Copy
                </button>
            </div>
        </div>
    {% endif %}

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5>Add Member by Email</h5>

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Email address</label>
                    <input type="email"
                           name="email"
                           class="form-control"
                           placeholder="example@email.com"
                           required>
                </div>

                <button type="submit" class="btn btn-primary">
                    Generate Invite Link
                </button>
            </form>
        </div>
    </div>
    <div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5>Pending Invitations</h5>

        {% set hasPendingInvitations = false %}

        {% for invitation in workspace.invitations %}
            {% if invitation.status == 'pending' %}
                {% set hasPendingInvitations = true %}

                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div>
                        <strong>{{ invitation.email }}</strong><br>
                        <small class="text-muted">
                            Expires: {{ invitation.expiresAt|date('d/m/Y H:i') }}
                        </small>
                    </div>

                    <div>
    <span class="badge bg-warning text-dark me-2">
        Pending
    </span>

    <a href="{{ path('app_workspace_invitation_delete', {
        id: invitation.id
    }) }}"
       class="btn btn-sm btn-danger"
       onclick="return confirm('Delete this invitation?')">
        Cancel
    </a>
</div>
                </div>
            {% endif %}
        {% endfor %}

        {% if not hasPendingInvitations %}
            <p class="text-muted mb-0">No pending invitations.</p>
        {% endif %}
    </div>
</div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h5>Current Members</h5>

            {% for member in workspace.members %}
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div>
                        <strong>{{ member.user.fullName }}</strong><br>
                        <small class="text-muted">{{ member.user.email }}</small>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                            {% if member.role == 'owner' %}
                                <span class="badge bg-danger">Owner</span>
                            {% elseif app.user == workspace.owner %}
                                <form method="post"
                                    action="{{ path('app_workspace_member_role', {'id': member.id}) }}"
                                    class="d-flex align-items-center gap-2">

                                    <select name="role" class="form-select form-select-sm">
                                        <option value="member" {{ member.role == 'member' ? 'selected' : '' }}>
                                            Member
                                        </option>
                                        <option value="admin" {{ member.role == 'admin' ? 'selected' : '' }}>
                                            Admin
                                        </option>
                                    </select>

                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                        Save
                                    </button>
                                </form>

                                <a href="{{ path('app_workspace_member_remove', {'id': member.id}) }}"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('Remove this member?')">
                                    Remove
                                </a>
                                {% else %}
    <span class="badge bg-secondary">{{ member.role|capitalize }}</span>

    {% if member.role == 'member' %}
        <a href="{{ path('app_workspace_member_remove', {'id': member.id}) }}"
           class="btn btn-danger btn-sm"
           onclick="return confirm('Remove this member?')">
            Remove
        </a>
    {% endif %}
{% endif %}
                            
                        </div>
                </div>
            {% else %}
                <p class="text-muted">No members yet.</p>
            {% endfor %}
        </div>
    </div>

</div>
{% endblock %}
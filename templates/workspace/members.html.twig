{% extends 'base.html.twig' %}

{% block title %}Members{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Workspace
    </a>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>{{ workspace.name }} Members</h1>

        <a href="{{ path('app_workspace_invite', {'id': workspace.id}) }}"
           class="btn btn-outline-warning">
            Invite Member
        </a>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h5>Add Member</h5>

            {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.user) }}
                    {{ form_widget(form.user, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.user) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.role) }}
                    {{ form_widget(form.role, {'attr': {'class': 'form-select'}}) }}
                    {{ form_errors(form.role) }}
                </div>

                <button class="btn btn-primary">
                    Add Member
                </button>

            {{ form_end(form) }}
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-body">

            <h5>Current Members</h5>

            {% for member in workspace.members %}
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                    <div>
                        <strong>{{ member.user.fullName }}</strong>
                        <small class="text-muted d-block">
                            {{ member.user.email }}
                        </small>
                    </div>

                    <div>
                        {% if member.role == 'owner' %}
                            <span class="badge bg-danger me-2">Owner</span>
                        {% else %}

                            {% if app.user == workspace.owner %}
                                <form method="post"
                                      action="{{ path('app_workspace_member_role', {'id': member.id}) }}"
                                      class="d-inline-flex align-items-center me-2">

                                    <select name="role" class="form-select form-select-sm me-2">
                                        <option value="member" {% if member.role == 'member' %}selected{% endif %}>
                                            Member
                                        </option>

                                        <option value="admin" {% if member.role == 'admin' %}selected{% endif %}>
                                            Admin
                                        </option>
                                    </select>

                                    <button class="btn btn-sm btn-outline-primary me-2">
                                        Save
                                    </button>
                                </form>
                            {% else %}
                                {% if member.role == 'admin' %}
                                    <span class="badge bg-warning text-dark me-2">Admin</span>
                                {% else %}
                                    <span class="badge bg-secondary me-2">Member</span>
                                {% endif %}
                            {% endif %}

                            {% if app.user == workspace.owner or member.role == 'member' %}
                                <a href="{{ path('app_workspace_member_remove', {'id': member.id}) }}"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Remove member?')">
                                    Remove
                                </a>
                            {% endif %}

                        {% endif %}
                    </div>
                </div>
            {% else %}
                <p class="text-muted mb-0">No members found.</p>
            {% endfor %}

        </div>
    </div>

</div>
{% endblock %}
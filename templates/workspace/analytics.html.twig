{% extends 'base.html.twig' %}

{% block title %}Workspace Analytics{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_workspace_show', {'id': workspace.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Workspace
    </a>

    <h1 class="mb-4">📊 {{ workspace.name }} Analytics</h1>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>Projects</h5>
                    <h2>{{ totalProjects }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>Members</h5>
                    <h2>{{ membersCount }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h5>Total Tasks</h5>
                    <h2>{{ totalTasks }}</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-3">

        <div class="col-md-4 mb-3">
            <div class="card border-secondary text-center">
                <div class="card-body">
                    <h5>Todo</h5>
                    <h2>{{ todoTasks }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-warning text-center">
                <div class="card-body">
                    <h5>In Progress</h5>
                    <h2>{{ inProgressTasks }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-success text-center">
                <div class="card-body">
                    <h5>Done</h5>
                    <h2>{{ doneTasks }}</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5>Completion Rate</h5>

            <div class="progress mt-3" style="height: 30px;">
                <div class="progress-bar"
                     role="progressbar"
                     style="width: {{ completionRate }}%">
                    {{ completionRate }}%
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
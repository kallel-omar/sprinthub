{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="container mt-5">

    <h1 class="mb-4">🚀 SprintHub Dashboard</h1>

    <p class="text-muted">
        Welcome back, <strong>{{ app.user.fullName }}</strong>
    </p>

    <div class="row mt-4">

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6>Total Workspaces</h6>
                    <h2>{{ totalWorkspaces }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6>Total Projects</h6>
                    <h2>{{ totalProjects }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6>My Tasks</h6>
                    <h2>{{ myTotalTasks }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <h6>Unread Notifications</h6>
                    <h2>{{ unreadNotifications }}</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-3">

        <div class="col-md-4 mb-3">
            <div class="card border-secondary text-center">
                <div class="card-body">
                    <h5>My Todo</h5>
                    <h2>{{ myTodoTasks }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-warning text-center">
                <div class="card-body">
                    <h5>My In Progress</h5>
                    <h2>{{ myInProgressTasks }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-success text-center">
                <div class="card-body">
                    <h5>My Completed</h5>
                    <h2>{{ myDoneTasks }}</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5>My Completion Rate</h5>

            <div class="progress mt-3" style="height: 30px;">
                <div class="progress-bar"
                     role="progressbar"
                     style="width: {{ myCompletionRate }}%">
                    {{ myCompletionRate }}%
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">

        <div class="col-md-4 mb-3">
            <div class="card border-danger text-center">
                <div class="card-body">
                    <h5>⚠️ Overdue</h5>
                    <h2>{{ overdueTasks|length }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-warning text-center">
                <div class="card-body">
                    <h5>📅 Due Today</h5>
                    <h2>{{ dueTodayTasks|length }}</h2>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card border-info text-center">
                <div class="card-body">
                    <h5>📆 Due This Week</h5>
                    <h2>{{ dueThisWeekTasks|length }}</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <h5>⏰ Deadline Tasks</h5>

            <h6 class="text-danger mt-3">Overdue</h6>
            {% for task in overdueTasks %}
                <div class="border-bottom py-2">
                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                       class="text-decoration-none fw-bold">
                        {{ task.title }}
                    </a>

                    <small class="text-danger d-block">
                        Due: {{ task.dueDate|date('d/m/Y') }}
                    </small>
                </div>
            {% else %}
                <p class="text-muted">No overdue tasks.</p>
            {% endfor %}

            <h6 class="text-warning mt-3">Due Today</h6>
            {% for task in dueTodayTasks %}
                <div class="border-bottom py-2">
                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                       class="text-decoration-none fw-bold">
                        {{ task.title }}
                    </a>

                    <small class="text-warning d-block">
                        Due: {{ task.dueDate|date('d/m/Y') }}
                    </small>
                </div>
            {% else %}
                <p class="text-muted">No tasks due today.</p>
            {% endfor %}

            <h6 class="text-info mt-3">Due This Week</h6>
            {% for task in dueThisWeekTasks %}
                <div class="border-bottom py-2">
                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                       class="text-decoration-none fw-bold">
                        {{ task.title }}
                    </a>

                    <small class="text-info d-block">
                        Due: {{ task.dueDate|date('d/m/Y') }}
                    </small>
                </div>
            {% else %}
                <p class="text-muted">No tasks due this week.</p>
            {% endfor %}
        </div>
    </div>

    <div class="row mt-4">

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>✅ My Recent Tasks</h5>

                    {% for task in myTasks %}
                        <div class="border-bottom py-2">
                            <strong>
                                <a href="{{ path('app_task_show', {'id': task.id}) }}"
                                   class="text-decoration-none">
                                    {{ task.title }}
                                </a>
                            </strong>

                            <span class="badge bg-secondary ms-2">
                                {{ task.status }}
                            </span>

                            {% if task.dueDate %}
                                <small class="text-danger d-block">
                                    Due: {{ task.dueDate|date('d/m/Y') }}
                                </small>
                            {% endif %}
                        </div>
                    {% else %}
                        <p class="text-muted mt-3">
                            No assigned tasks yet.
                        </p>
                    {% endfor %}

                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5>📜 Recent Activity</h5>

                    {% for activity in recentActivities %}
                        <div class="border-bottom py-2">
                            <span>{{ activity.message }}</span>

                            <small class="text-muted d-block">
                                {{ activity.createdAt|date('d/m/Y H:i') }}
                            </small>
                        </div>
                    {% else %}
                        <p class="text-muted mt-3">
                            No activity yet.
                        </p>
                    {% endfor %}

                </div>
            </div>
        </div>

    </div>

</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">🔔 Notifications</h1>

        {% if notifications is not empty %}
            <div class="d-flex gap-2">

                <form method="post"
                      action="{{ path('app_notification_mark_all_read') }}">
                    <button type="submit"
                            class="btn btn-outline-success btn-sm">
                        Mark all as read
                    </button>
                </form>

                <form method="post"
                      action="{{ path('app_notification_delete_normal') }}"
                      onsubmit="return confirm('Delete all normal notifications? Pending invitations will be kept.');">
                    <button type="submit"
                            class="btn btn-outline-danger btn-sm">
                        Delete all notifications
                    </button>
                </form>

            </div>
        {% endif %}
    </div>

    {% if notifications is empty %}
        <div class="alert alert-info">
            You have no notifications.
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body">

                {% for notification in notifications %}
                    <div class="d-flex justify-content-between align-items-center border-bottom py-3">

                        <div>

                            {% if notification.link %}
                                <a href="{{ path('app_notification_open', {'id': notification.id}) }}"
                                   class="text-decoration-none {% if notification.isRead %}text-muted{% else %}text-dark fw-bold{% endif %}">
                                    {{ notification.message }}
                                </a>
                            {% else %}
                                {% if notification.isRead %}
                                    <span class="text-muted">
                                        {{ notification.message }}
                                    </span>
                                {% else %}
                                    <strong>
                                        {{ notification.message }}
                                    </strong>
                                {% endif %}
                            {% endif %}

                            {% if not notification.isRead %}
                                <span class="badge bg-primary ms-2">
                                    New
                                </span>
                            {% endif %}

                            <small class="text-muted d-block">
                                {{ notification.createdAt|date('d/m/Y H:i') }}
                            </small>

                        </div>

                        <div class="d-flex gap-2">

                            {% if not notification.isRead %}

                                {% if notification.link and 'invite/accept' in notification.link %}

                                    <a href="{{ notification.link }}"
                                       class="btn btn-sm btn-success">
                                        Accept
                                    </a>

                                    <a href="{{ path('app_notification_decline', {'id': notification.id}) }}"
                                       class="btn btn-sm btn-danger">
                                        Decline
                                    </a>

                                {% elseif notification.link %}

                                    <a href="{{ path('app_notification_open', {'id': notification.id}) }}"
                                       class="btn btn-sm btn-outline-primary">
                                        Open
                                    </a>

                                {% else %}

                                    <a href="{{ path('app_notification_read', {'id': notification.id}) }}"
                                       class="btn btn-sm btn-outline-success">
                                        Mark as read
                                    </a>

                                {% endif %}

                            {% endif %}

                            {% if not (not notification.isRead and notification.link and 'invite/accept' in notification.link) %}
                                <form method="post"
                                      action="{{ path('app_notification_delete', {'id': notification.id}) }}"
                                      onsubmit="return confirm('Delete this notification?');">

                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger">
                                        Delete
                                    </button>

                                </form>
                            {% endif %}

                        </div>

                    </div>
                {% endfor %}

            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
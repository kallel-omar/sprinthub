{% extends 'base.html.twig' %}

{% block title %}Join Requests{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_dashboard') }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Dashboard
    </a>

    <div class="card shadow-sm">
        <div class="card-body">

            <h1 class="mb-4">🙋 Project Join Requests</h1>

            {% if joinRequests is empty %}
                <div class="alert alert-info mb-0">
                    No pending join requests.
                </div>
            {% else %}
                {% for joinRequest in joinRequests %}
                    <div class="d-flex justify-content-between align-items-center border-bottom py-3">

                        <div>
                            <h5 class="mb-1">
                                {{ joinRequest.user.fullName }}
                            </h5>

                            <small class="text-muted d-block">
                                Email: {{ joinRequest.user.email }}
                            </small>

                            <small class="text-muted d-block">
                                Project: {{ joinRequest.project.name }}
                            </small>

                            <small class="text-muted d-block">
                                Workspace: {{ joinRequest.project.workspace.name }}
                            </small>

                            <small class="text-muted d-block">
                                Requested on {{ joinRequest.createdAt|date('d/m/Y H:i') }}
                            </small>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_project_join_request_approve', {'id': joinRequest.id}) }}"
                               class="btn btn-sm btn-success">
                                Approve
                            </a>

                            <a href="{{ path('app_project_join_request_reject', {'id': joinRequest.id}) }}"
                               class="btn btn-sm btn-outline-danger">
                                Reject
                            </a>
                        </div>

                    </div>
                {% endfor %}
            {% endif %}

        </div>
    </div>

</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}{{ project.name }}{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_workspace_show', {'id': project.workspace.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Workspace
    </a>

    <div class="card shadow-sm">
        <div class="card-body">

            <h1>{{ project.name }}</h1>

            <p class="text-muted">
                Workspace: {{ project.workspace.name }}
            </p>

            <p>{{ project.description|default('No description') }}</p>

            <hr>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>Kanban Board</h4>

                <a href="{{ path('app_task_new', {'id': project.id}) }}"
                   class="btn btn-primary">
                    Create Task
                </a>
            </div>

            <div class="row">

                {# TO DO #}
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-header fw-bold">To Do</div>

                        <div class="card-body">
                            {% for task in project.tasks %}
                                {% if task.status == 'todo' %}
                                    <div class="card mb-2">
                                        <div class="card-body">
                                           <h6>
    <a href="{{ path('app_task_show', {'id': task.id}) }}"
       class="text-decoration-none">
        {{ task.title }}
    </a>
</h6>

                                            <p class="text-muted small">
                                                {{ task.description|default('No description') }}
                                            </p>

                                            {% if task.dueDate %}
                                                <p class="small text-danger mt-2 mb-1">
                                                    📅 Due: {{ task.dueDate|date('d/m/Y') }}
                                                </p>
                                            {% endif %}

                                            {% if task.assignee %}
                                                <p class="small text-primary mb-1">
                                                    👤 Assigned to: {{ task.assignee.fullName }}
                                                </p>
                                            {% endif %}

                                            <span class="badge bg-primary">{{ task.priority }}</span>

                                            <br>

                                            <a href="{{ path('app_task_start', {'id': task.id}) }}"
                                               class="btn btn-warning btn-sm mt-2">
                                                Start
                                            </a>

                                            <a href="{{ path('app_task_edit', {'id': task.id}) }}"
                                               class="btn btn-outline-primary btn-sm mt-2">
                                                Edit
                                            </a>

                                            <a href="{{ path('app_task_delete', {'id': task.id}) }}"
                                               class="btn btn-outline-danger btn-sm mt-2"
                                               onclick="return confirm('Are you sure you want to delete this task?');">
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# IN PROGRESS #}
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-header fw-bold">In Progress</div>

                        <div class="card-body">
                            {% for task in project.tasks %}
                                {% if task.status == 'in_progress' %}
                                    <div class="card mb-2">
                                        <div class="card-body">
                                            <h6>
    <a href="{{ path('app_task_show', {'id': task.id}) }}"
       class="text-decoration-none">
        {{ task.title }}
    </a>
</h6>

                                            <p class="text-muted small">
                                                {{ task.description|default('No description') }}
                                            </p>

                                            {% if task.dueDate %}
                                                <p class="small text-danger mt-2 mb-1">
                                                    📅 Due: {{ task.dueDate|date('d/m/Y') }}
                                                </p>
                                            {% endif %}

                                            {% if task.assignee %}
                                                <p class="small text-primary mb-1">
                                                    👤 Assigned to: {{ task.assignee.fullName }}
                                                </p>
                                            {% endif %}

                                            <span class="badge bg-warning text-dark">{{ task.priority }}</span>

                                            <br>

                                            <a href="{{ path('app_task_done', {'id': task.id}) }}"
                                               class="btn btn-success btn-sm mt-2">
                                                Complete
                                            </a>

                                            <a href="{{ path('app_task_edit', {'id': task.id}) }}"
                                               class="btn btn-outline-primary btn-sm mt-2">
                                                Edit
                                            </a>

                                            <a href="{{ path('app_task_delete', {'id': task.id}) }}"
                                               class="btn btn-outline-danger btn-sm mt-2"
                                               onclick="return confirm('Are you sure you want to delete this task?');">
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# DONE #}
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-header fw-bold">Done</div>

                        <div class="card-body">
                            {% for task in project.tasks %}
                                {% if task.status == 'done' %}
                                    <div class="card mb-2">
                                        <div class="card-body">
                                            <h6>
    <a href="{{ path('app_task_show', {'id': task.id}) }}"
       class="text-decoration-none">
        {{ task.title }}
    </a>
</h6>
                                            <p class="text-muted small">
                                                {{ task.description|default('No description') }}
                                            </p>

                                            {% if task.dueDate %}
                                                <p class="small text-danger mt-2 mb-1">
                                                    📅 Due: {{ task.dueDate|date('d/m/Y') }}
                                                </p>
                                            {% endif %}

                                            {% if task.assignee %}
                                                <p class="small text-primary mb-1">
                                                    👤 Assigned to: {{ task.assignee.fullName }}
                                                </p>
                                            {% endif %}

                                            <span class="badge bg-success">{{ task.priority }}</span>

                                            <br>

                                            <a href="{{ path('app_task_edit', {'id': task.id}) }}"
                                               class="btn btn-outline-primary btn-sm mt-2">
                                                Edit
                                            </a>

                                            <a href="{{ path('app_task_delete', {'id': task.id}) }}"
                                               class="btn btn-outline-danger btn-sm mt-2"
                                               onclick="return confirm('Are you sure you want to delete this task?');">
                                                Delete
                                            </a>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </div>

</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}{{ project.name }}{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_workspace_show', {'id': project.workspace.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Workspace
    </a>

    <div class="card shadow-sm">
        <div class="card-body">

            <h1>{{ project.name }}</h1>

            <p class="text-muted">
                Workspace: {{ project.workspace.name }}
            </p>

            <p>{{ project.description|default('No description') }}</p>

            <hr>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <a href="{{ path('app_task_new', {'id': project.id}) }}"
                   class="btn btn-primary">
                    Create Task
                </a>
            </div>

            <form method="get" class="mb-4">
                <div class="row g-2">

                    <div class="col-md-3">
                        <input type="text"
                               name="search"
                               class="form-control"
                               placeholder="Search tasks..."
                               value="{{ search|default('') }}">
                    </div>

                    <div class="col-md-2">
                        <select name="priority" class="form-select">
                            <option value="">All Priorities</option>
                            <option value="Low" {{ priority == 'Low' ? 'selected' : '' }}>Low</option>
                            <option value="Medium" {{ priority == 'Medium' ? 'selected' : '' }}>Medium</option>
                            <option value="High" {{ priority == 'High' ? 'selected' : '' }}>High</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select name="status" class="form-select">
                            <option value="">All Statuses</option>
                            <option value="todo" {{ status == 'todo' ? 'selected' : '' }}>To Do</option>
                            <option value="in_progress" {{ status == 'in_progress' ? 'selected' : '' }}>In Progress</option>
                            <option value="done" {{ status == 'done' ? 'selected' : '' }}>Done</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <select name="label" class="form-select">
                            <option value="">All Labels</option>

                            {% for label in labels %}
                                <option value="{{ label.id }}"
                                    {{ selectedLabel == label.id ? 'selected' : '' }}>
                                    {{ label.name }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button class="btn btn-primary w-100">
                            Filter
                        </button>
                    </div>

                </div>
            </form>

            <div class="card mb-4">
                <div class="card-body">
                    <h5>Project Members</h5>

                    <div class="mb-3">
    {% if project.members is not empty %}
        {% for member in project.members %}

            {% set memberRole = 'member' %}

            {% for workspaceMember in project.workspace.members %}
                {% if workspaceMember.user.id == member.id %}
                    {% set memberRole = workspaceMember.role %}
                {% endif %}
            {% endfor %}

            <span class="badge
                {% if memberRole == 'owner' %}
                    bg-danger
                {% elseif memberRole == 'admin' %}
                    bg-warning text-dark
                {% else %}
                    bg-primary
                {% endif %}
                me-1">

                👤 {{ member.fullName }}

                {% if memberRole == 'owner' %}
                    (Owner)
                {% elseif memberRole == 'admin' %}
                    (Admin)
                {% else %}
                    (Member)
                {% endif %}
            </span>

        {% endfor %}
    {% else %}
        <p class="text-muted mb-0">No members yet.</p>
    {% endif %}
</div>

                    {% if canManageProjectMembers %}
    <hr>

    {{ form_start(memberForm) }}
        {{ form_widget(memberForm) }}

        <button class="btn btn-primary">
            Add Member
        </button>
    {{ form_end(memberForm) }}
{% endif %}
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>Kanban Board</h4>

                <div class="d-flex gap-2">
                    <a href="{{ path('app_project_stats', {'id': project.id}) }}"
                       class="btn btn-outline-success">
                        Statistics
                    </a>

                    <button type="button"
                            class="btn btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteProjectModal{{ project.id }}">
                        Delete Project
                    </button>
                </div>
            </div>

            <div class="modal fade" id="deleteProjectModal{{ project.id }}" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">

                        <div class="modal-header">
                            <h5 class="modal-title">Delete Project</h5>
                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body">
                            Are you sure you want to delete
                            <strong>{{ project.name }}</strong>?

                            <div class="alert alert-warning mt-3 mb-0">
                                This action will permanently delete the project and all its tasks.
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button"
                                    class="btn btn-secondary"
                                    data-bs-dismiss="modal">
                                Cancel
                            </button>

                            <a href="{{ path('app_project_delete', {'id': project.id}) }}"
                               class="btn btn-danger">
                                Yes, delete project
                            </a>
                        </div>

                    </div>
                </div>
            </div>

            <div class="row">

                {% set statuses = {
                    'todo': 'To Do',
                    'in_progress': 'In Progress',
                    'done': 'Done'
                } %}

                {% for statusKey, statusLabel in statuses %}
                    <div class="col-md-4">
                        <div class="card shadow-sm">
                            <div class="card-header fw-bold">
                                {{ statusLabel }}
                            </div>

                            <div class="card-body kanban-column"
                                 data-status="{{ statusKey }}"
                                 style="min-height: 200px;">

                                {% for task in tasks %}
                                    {% if task.status == statusKey %}
                                        <div class="card mb-2 kanban-task"
                                             draggable="true"
                                             data-task-id="{{ task.id }}">
                                            <div class="card-body">

                                                <h6>
                                                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                                                       class="text-decoration-none">
                                                        {{ task.title }}
                                                    </a>
                                                </h6>

                                                <p class="text-muted small">
                                                    {{ task.description|default('No description') }}
                                                </p>

                                                {% if task.dueDate %}
                                                    <p class="small text-danger mt-2 mb-1">
                                                        📅 Due: {{ task.dueDate|date('d/m/Y') }}
                                                    </p>
                                                {% endif %}

                                                {% if task.assignee %}
                                                    <p class="small text-primary mb-1">
                                                        👤 Assigned to: {{ task.assignee.fullName }}
                                                    </p>
                                                {% endif %}

                                                {% if task.labels is not empty %}
                                                    <div class="mb-2">
                                                        {% for label in task.labels %}
                                                            <span class="badge bg-{{ label.color }} me-1">
                                                                {{ label.name }}
                                                            </span>
                                                        {% endfor %}
                                                    </div>
                                                {% endif %}

                                                {% if task.priority == 'High' %}
                                                    <span class="badge bg-warning text-dark">
                                                        {{ task.priority }}
                                                    </span>
                                                {% elseif task.priority == 'Medium' %}
                                                    <span class="badge bg-info text-dark">
                                                        {{ task.priority }}
                                                    </span>
                                                {% else %}
                                                    <span class="badge bg-secondary">
                                                        {{ task.priority }}
                                                    </span>
                                                {% endif %}

                                                {% if task.checklistTotalCount > 0 %}
                                                    <div class="mt-2">
                                                        <small class="text-muted">
                                                            Progress:
                                                            {{ task.checklistCompletedCount }}/{{ task.checklistTotalCount }}
                                                        </small>

                                                        <div class="progress mt-1" style="height: 8px;">
                                                            <div class="progress-bar bg-success"
                                                                 role="progressbar"
                                                                 style="width: {{ task.checklistProgress }}%;">
                                                            </div>
                                                        </div>

                                                        <small class="text-success">
                                                            {{ task.checklistProgress }}%
                                                        </small>
                                                    </div>
                                                {% endif %}

                                                <br>

                                                <a href="{{ path('app_task_edit', {'id': task.id}) }}"
                                                   class="btn btn-outline-primary btn-sm mt-2">
                                                    Edit
                                                </a>

                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm mt-2"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteTaskModal{{ task.id }}">
                                                    Delete
                                                </button>

                                                <div class="modal fade" id="deleteTaskModal{{ task.id }}" tabindex="-1">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">

                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Delete Task</h5>
                                                                <button type="button"
                                                                        class="btn-close"
                                                                        data-bs-dismiss="modal"></button>
                                                            </div>

                                                            <div class="modal-body">
                                                                Are you sure you want to delete
                                                                <strong>{{ task.title }}</strong>?
                                                            </div>

                                                            <div class="modal-footer">
                                                                <button type="button"
                                                                        class="btn btn-secondary btn-sm"
                                                                        data-bs-dismiss="modal">
                                                                    Cancel
                                                                </button>

                                                                <a href="{{ path('app_task_delete', {'id': task.id}) }}"
                                                                   class="btn btn-danger btn-sm">
                                                                    Yes, delete
                                                                </a>
                                                            </div>

                                                        </div>
                                                    </div>
                                                </div>

                                            </div>
                                        </div>
                                    {% endif %}
                                {% endfor %}

                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>

        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
<script>
    let draggedTask = null;

    document.querySelectorAll('.kanban-task').forEach(task => {
        task.addEventListener('dragstart', function () {
            draggedTask = this;
            this.classList.add('opacity-50');
        });

        task.addEventListener('dragend', function () {
            this.classList.remove('opacity-50');
        });
    });

    document.querySelectorAll('.kanban-column').forEach(column => {
        column.addEventListener('dragover', function (event) {
            event.preventDefault();
        });

        column.addEventListener('drop', function () {
            if (!draggedTask) {
                return;
            }

            const taskId = draggedTask.dataset.taskId;
            const newStatus = this.dataset.status;

            this.appendChild(draggedTask);

            fetch(`/tasks/${taskId}/status`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    status: newStatus
                })
            })
            .then(response => response.json())
            .then(data => {
                if (!data.success) {
                    alert('Could not update task status.');
                    location.reload();
                }
            })
            .catch(() => {
                alert('Error updating task status.');
                location.reload();
            });
        });
    });
</script>
{% endblock %}
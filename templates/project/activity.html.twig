{% extends 'base.html.twig' %}

{% block title %}Activity - {{ project.name }}{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_project_show', {'id': project.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Project
    </a>

    <div class="card shadow-sm">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="mb-1">Activity Log</h1>
                    <p class="text-muted mb-0">
                        Project: {{ project.name }}
                    </p>
                </div>
            </div>

            <div class="mb-4 d-flex flex-wrap gap-2">
                <a href="{{ path('app_project_activity', {'id': project.id}) }}"
                   class="btn btn-sm {{ selectedType is empty ? 'btn-primary' : 'btn-outline-primary' }}">
                    All
                </a>

                {% set filters = {
                    'task': 'Tasks',
                    'comment': 'Comments',
                    'attachment': 'Files',
                    'file': 'Deleted Files',
                    'checklist': 'Checklist',
                    'member': 'Members',
                    'project': 'Projects'
                } %}

                {% for type, label in filters %}
                    <a href="{{ path('app_project_activity', {'id': project.id, 'type': type}) }}"
                       class="btn btn-sm {{ selectedType == type ? 'btn-primary' : 'btn-outline-primary' }}">
                        {{ label }}
                    </a>
                {% endfor %}
            </div>

            {% if logs is empty %}
                <div class="alert alert-info mb-0">
                    No activity found for this filter.
                </div>
            {% else %}
                <div class="list-group">

                    {% for log in logs %}
                        <div class="list-group-item">

                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-bold">
                                        {{ log.message }}
                                    </div>

                                    <small class="text-muted">
                                        By {{ log.user ? log.user.fullName : 'Unknown user' }}
                                        · {{ log.createdAt|date('d/m/Y H:i') }}
                                    </small>

                                    {% if log.task %}
                                        <div class="mt-2">
                                            <a href="{{ path('app_task_show', {'id': log.task.id}) }}"
                                               class="btn btn-sm btn-outline-secondary">
                                                Open Task
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>

                                <span class="badge bg-secondary">
                                    {{ log.type }}
                                </span>
                            </div>

                        </div>
                    {% endfor %}

                </div>
            {% endif %}

        </div>
    </div>

</div>
{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}{{ task.title }}{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_project_show', {'id': task.project.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Project
    </a>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1>{{ task.title }}</h1>

            <p class="text-muted">
                Status: {{ task.status }}
            </p>

            <p>
                {{ task.description|default('No description') }}
            </p>
        </div>
    </div>

    <h4>Checklist</h4>

    <div class="card mb-4">
        <div class="card-body">

            <div class="mb-4">
                <div class="d-flex justify-content-between">
                    <strong>
                        Progress:
                        {{ task.checklistCompletedCount }}
                        /
                        {{ task.checklistTotalCount }}
                        completed
                    </strong>

                    <strong>
                        {{ task.checklistProgress }}%
                    </strong>
                </div>

                <div class="progress mt-2" style="height: 25px;">
                    <div class="progress-bar bg-success"
                         role="progressbar"
                         style="width: {{ task.checklistProgress }}%;">
                        {{ task.checklistProgress }}%
                    </div>
                </div>
            </div>

            {% for item in task.checklistItems %}
                <div class="d-flex justify-content-between align-items-center border-bottom py-2">

                    <div>
                        {% if item.isDone %}
                            ✅ <span class="text-decoration-line-through text-muted">
                                {{ item.content }}
                            </span>
                        {% else %}
                            ⬜ {{ item.content }}
                        {% endif %}
                    </div>

                    <div>
                        <a href="{{ path('app_checklist_toggle', {'id': item.id}) }}"
                           class="btn btn-sm btn-outline-success">
                            Toggle
                        </a>

                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteChecklistModal{{ item.id }}">
                            Delete
                        </button>

                        <div class="modal fade" id="deleteChecklistModal{{ item.id }}" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">

                                    <div class="modal-header">
                                        <h5 class="modal-title">Delete checklist item</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>

                                    <div class="modal-body">
                                        Are you sure you want to delete:
                                        <strong>{{ item.content }}</strong>?
                                    </div>

                                    <div class="modal-footer">
                                        <button type="button"
                                                class="btn btn-secondary btn-sm"
                                                data-bs-dismiss="modal">
                                            Cancel
                                        </button>

                                        <a href="{{ path('app_checklist_delete', {'id': item.id}) }}"
                                           class="btn btn-danger btn-sm">
                                            Yes, delete
                                        </a>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            {% else %}
                <p class="text-muted">No checklist items yet.</p>
            {% endfor %}

            <hr>

            <h5>Add Checklist Item</h5>

            {{ form_start(checklistForm) }}
                {{ form_widget(checklistForm) }}

                <button class="btn btn-primary mt-2">
                    Add Item
                </button>
            {{ form_end(checklistForm) }}

        </div>
    </div>

    <h4>Attachments</h4>

    {% for attachment in task.attachments %}
        <div class="card mb-2">
            <div class="card-body d-flex justify-content-between align-items-center">

                <div>
                    📎
                    <a href="{{ asset('uploads/tasks/' ~ attachment.fileName) }}" target="_blank">
                        {{ attachment.originalName }}
                    </a>

                    <small class="text-muted d-block">
                        Uploaded by {{ attachment.uploadedBy.fullName }}
                        on {{ attachment.createdAt|date('d/m/Y H:i') }}
                    </small>
                </div>

                {% if attachment.uploadedBy == app.user %}
                    <button type="button"
                            class="btn btn-sm btn-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteAttachmentModal{{ attachment.id }}">
                        Delete
                    </button>

                    <div class="modal fade" id="deleteAttachmentModal{{ attachment.id }}" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">

                                <div class="modal-header">
                                    <h5 class="modal-title">Delete attachment</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    Are you sure you want to delete:
                                    <strong>{{ attachment.originalName }}</strong>?
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="btn btn-secondary btn-sm"
                                            data-bs-dismiss="modal">
                                        Cancel
                                    </button>

                                    <a href="{{ path('app_attachment_delete', {'id': attachment.id}) }}"
                                       class="btn btn-danger btn-sm">
                                        Yes, delete
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                {% endif %}

            </div>
        </div>
    {% else %}
        <p class="text-muted">No attachments yet.</p>
    {% endfor %}

    <div class="card mt-4 mb-4">
        <div class="card-body">
            <h5>Upload Attachment</h5>

            {{ form_start(attachmentForm) }}
                {{ form_widget(attachmentForm) }}

                <button class="btn btn-secondary mt-2">
                    Upload File
                </button>
            {{ form_end(attachmentForm) }}
        </div>
    </div>

    <h4>Comments</h4>

    {% for comment in task.comments %}
        <div class="card mb-2">
            <div class="card-body d-flex justify-content-between align-items-start">

                <div>
                    <strong>{{ comment.user.fullName }}</strong>

                    <small class="text-muted">
                        {{ comment.createdAt|date('d/m/Y H:i') }}
                    </small>

                    <p class="mb-0 mt-2">
                        {{ comment.content }}
                    </p>
                </div>

                {% if comment.user == app.user %}
                    <button type="button"
                            class="btn btn-sm btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteCommentModal{{ comment.id }}">
                        Delete
                    </button>

                    <div class="modal fade" id="deleteCommentModal{{ comment.id }}" tabindex="-1">
                        <div class="modal-dialog">
                            <div class="modal-content">

                                <div class="modal-header">
                                    <h5 class="modal-title">Delete comment</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="modal-body">
                                    Are you sure you want to delete this comment?
                                </div>

                                <div class="modal-footer">
                                    <button type="button"
                                            class="btn btn-secondary btn-sm"
                                            data-bs-dismiss="modal">
                                        Cancel
                                    </button>

                                    <a href="{{ path('app_comment_delete', {'id': comment.id}) }}"
                                       class="btn btn-danger btn-sm">
                                        Yes, delete
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                {% endif %}

            </div>
        </div>
    {% else %}
        <p class="text-muted">No comments yet.</p>
    {% endfor %}

    <div class="card mt-4">
        <div class="card-body">
            <h5>Add Comment</h5>

            {{ form_start(commentForm) }}
                {{ form_widget(commentForm) }}

                <button class="btn btn-primary mt-2">
                    Add Comment
                </button>
            {{ form_end(commentForm) }}
        </div>
    </div>

</div>
{% endblock %}
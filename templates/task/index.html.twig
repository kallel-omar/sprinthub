{% extends 'base.html.twig' %}

{% block title %}My Tasks{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>✅ My Tasks</h1>

            <p class="text-muted mb-0">
                All tasks assigned to you across all projects and workspaces.
            </p>
        </div>

        <a href="{{ path('app_dashboard') }}"
           class="btn btn-outline-secondary">
            Back to Dashboard
        </a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex flex-wrap gap-2">

            <a href="{{ path('app_task_index') }}"
               class="btn btn-sm {% if not status and not deadline %}btn-dark{% else %}btn-outline-dark{% endif %}">
                All
            </a>

            <a href="{{ path('app_task_index', {'status': 'todo'}) }}"
               class="btn btn-sm {% if status == 'todo' %}btn-secondary{% else %}btn-outline-secondary{% endif %}">
                Todo
            </a>

            <a href="{{ path('app_task_index', {'status': 'in_progress'}) }}"
               class="btn btn-sm {% if status == 'in_progress' %}btn-warning{% else %}btn-outline-warning{% endif %}">
                In Progress
            </a>

            <a href="{{ path('app_task_index', {'status': 'done'}) }}"
               class="btn btn-sm {% if status == 'done' %}btn-success{% else %}btn-outline-success{% endif %}">
                Completed
            </a>

            <a href="{{ path('app_task_index', {'deadline': 'overdue'}) }}"
               class="btn btn-sm {% if deadline == 'overdue' %}btn-danger{% else %}btn-outline-danger{% endif %}">
                Overdue
            </a>

            <a href="{{ path('app_task_index', {'deadline': 'today'}) }}"
               class="btn btn-sm {% if deadline == 'today' %}btn-warning{% else %}btn-outline-warning{% endif %}">
                Due Today
            </a>

            <a href="{{ path('app_task_index', {'deadline': 'week'}) }}"
               class="btn btn-sm {% if deadline == 'week' %}btn-info{% else %}btn-outline-info{% endif %}">
                Due This Week
            </a>

        </div>
    </div>

    {% if tasks is empty %}
        <div class="alert alert-info">
            No tasks found.
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body">

                {% for task in tasks %}
                    <div class="border-bottom py-3">

                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="mb-1">
                                    <a href="{{ path('app_task_show', {'id': task.id}) }}"
                                       class="text-decoration-none">
                                        {{ task.title }}
                                    </a>
                                </h5>

                                <p class="text-muted mb-1">
                                    Project:
                                    <a href="{{ path('app_project_show', {'id': task.project.id}) }}"
                                       class="text-decoration-none">
                                        {{ task.project.name }}
                                    </a>
                                    —
                                    Workspace: {{ task.project.workspace.name }}
                                </p>

                                {% if task.description %}
                                    <p class="mb-1">
                                        {{ task.description|length > 120
                                            ? task.description|slice(0, 120) ~ '...'
                                            : task.description }}
                                    </p>
                                {% endif %}
                            </div>

                            <div class="text-end">
                                {% if task.status == 'todo' %}
                                    <span class="badge bg-secondary">Todo</span>
                                {% elseif task.status == 'in_progress' %}
                                    <span class="badge bg-warning text-dark">In Progress</span>
                                {% elseif task.status == 'done' %}
                                    <span class="badge bg-success">Done</span>
                                {% endif %}

                                {% if task.priority %}
                                    <span class="badge bg-dark">
                                        {{ task.priority }}
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        {% if task.dueDate %}
                            <small class="text-danger d-block mt-2">
                                Due: {{ task.dueDate|date('d/m/Y') }}
                            </small>
                        {% endif %}

                    </div>
                {% endfor %}

            </div>
        </div>
    {% endif %}

</div>
{% endblock %}
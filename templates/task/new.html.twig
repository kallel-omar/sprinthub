{% extends 'base.html.twig' %}

{% block title %}Create Task{% endblock %}

{% block body %}
<div class="container mt-5">

    <a href="{{ path('app_project_show', {'id': project.id}) }}"
       class="btn btn-outline-secondary btn-sm mb-3">
        ← Back to Project
    </a>

    <div class="card shadow-sm">
        <div class="card-body">

            <h1 class="mb-3">Create Task</h1>

            <p class="text-muted">
                Project: {{ project.name }}
            </p>

            {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.title) }}
                    {{ form_widget(form.title, {
                        attr: {
                            class: 'form-control'
                        }
                    }) }}
                    <div class="text-danger small mt-1">
                        {{ form_errors(form.title) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.description) }}
                    {{ form_widget(form.description, {
                        attr: {
                            class: 'form-control'
                        }
                    }) }}
                    <div class="text-danger small mt-1">
                        {{ form_errors(form.description) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.priority) }}
                    {{ form_widget(form.priority, {
                        attr: {
                            class: 'form-select'
                        }
                    }) }}
                    <div class="text-danger small mt-1">
                        {{ form_errors(form.priority) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.dueDate) }}
                    {{ form_widget(form.dueDate, {
                        attr: {
                            class: 'form-control'
                        }
                    }) }}
                    <div class="text-danger small mt-1">
                        {{ form_errors(form.dueDate) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.assignee) }}
                    {{ form_widget(form.assignee, {
                        attr: {
                            class: 'form-select'
                        }
                    }) }}
                    <div class="text-danger small mt-1">
                        {{ form_errors(form.assignee) }}
                    </div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.labels) }}
                    {{ form_widget(form.labels) }}
                    <div class="text-danger small mt-1">
                        {{ form_errors(form.labels) }}
                    </div>
                </div>

                <button type="submit" class="btn btn-primary">
                    Create Task
                </button>

            {{ form_end(form) }}

        </div>
    </div>

</div>
{% endblock %}
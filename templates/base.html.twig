<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}SprintHub{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>

<body class="bg-light">

{% include 'partials/_navbar.html.twig' %}

{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="container mt-3">
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="alert"
                        aria-label="Close">
                </button>
            </div>
        </div>
    {% endfor %}
{% endfor %}

{% block body %}{% endblock %}

{% include 'partials/_footer.html.twig' %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const notificationDropdown = document.getElementById('notificationDropdown');

    if (notificationDropdown) {
        notificationDropdown.addEventListener('shown.bs.dropdown', function () {
            fetch('{{ path('app_notification_mark_dropdown_read') }}', {
                method: 'POST'
            }).then(() => {
                const badge = notificationDropdown.querySelector('.badge');

                if (badge) {
                    badge.remove();
                }
            });
        });
    }
});
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    function updateNotificationCount() {
        fetch('{{ path('app_notification_live_count') }}')
            .then(response => response.json())
            .then(data => {
                const dropdown = document.getElementById('notificationDropdown');
                let badge = document.getElementById('notificationBadge');

                if (!dropdown) {
                    return;
                }

                if (data.count > 0) {
                    if (!badge) {
                        badge = document.createElement('span');
                        badge.id = 'notificationBadge';
                        badge.className = 'position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger';
                        dropdown.appendChild(badge);
                    }

                    badge.textContent = data.count;
                } else {
                    if (badge) {
                        badge.remove();
                    }
                }
            });
    }

    updateNotificationCount();

    setInterval(updateNotificationCount, 5000);
});
</script>

{% block javascripts %}{% endblock %}

</body>
</html>
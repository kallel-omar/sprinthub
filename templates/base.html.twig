<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}SprintHub{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    {% block stylesheets %}{% endblock %}
</head>

<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_dashboard') }}">SprintHub</a>

        <div class="navbar-nav ms-auto">
            {% if app.user %}
                <a class="nav-link" href="{{ path('app_dashboard') }}">Dashboard</a>
                <a class="nav-link" href="{{ path('app_workspace_index') }}">Workspaces</a>
                <a class="nav-link" href="{{ path('app_logout') }}">Logout</a>
            {% else %}
                <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                <a class="nav-link" href="{{ path('app_register') }}">Register</a>
            {% endif %}
        </div>
    </div>
</nav>

{% block body %}{% endblock %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}{% endblock %}
</body>
</html>